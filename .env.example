# Alpaca API credentials — paper trading (default)
# Get from: app.alpaca.markets → right sidebar → API Keys → Generate
# Env vars take precedence over credentials.yaml if both are set.
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# FRED API key — optional, only needed for very high request volume
FRED_API_KEY=optional_for_higher_rate_limits
